{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ReasoningOutput",
  "description": "Output schema for layout reasoning stages 1-3",
  "type": "object",
  "properties": {
    "primary_headline": { "type": ["string", "null"] },
    "value_statement": { "type": ["string", "null"] },
    "credibility_signals": { "type": ["string", "null"] },
    "page_type": { "type": "string" },
    "design_dna": {
      "type": "object",
      "properties": {
        "style": { "type": "string" },
        "mood": { "type": "string" },
        "formality": { "type": "number" },
        "typography_personality": { "type": "string" },
        "color_emotion": { "type": "string" },
        "spacing_feel": { "type": "string" },
        "brand_adjectives": { "type": "array", "items": { "type": "string" } },
        "design_reasoning": { "type": "string" }
      }
    },
    "analysis_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "regions": { "type": "array" },
    "detected_palette": {
      "type": "object",
      "properties": {
        "primary": { "type": "string" },
        "secondary": { "type": "string" },
        "accent": { "type": "string" }
      }
    },
    "detected_logo": { "type": "object" },
    "is_individual_profile": { "type": "boolean" }
  },
  "required": ["primary_headline", "page_type", "analysis_confidence"]
}
